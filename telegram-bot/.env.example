# Скопируйте в .env и подставьте значения (без лишних пробелов в конце строк)

# Токен от @BotFather
TELEGRAM_BOT_TOKEN=

# Тот же секрет, что TELEGRAM_BOT_API_SECRET в backend/.env
TELEGRAM_BOT_API_SECRET=TtsgBFELmLYnE0qXEECFu94ppWvHYcdMd

# URL FastAPI: тот же хост/порт, где открывается http://127.0.0.1:3000/docs
# Если бот и бэкенд на одном ПК — обычно:
API_BASE_URL=http://127.0.0.1:3000

# OpenAI: ответы ассистента на вопросы (модель gpt-4o-mini в коде)
