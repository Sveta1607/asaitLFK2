# URL API (должен заканчиваться на /api или будет добавлено автоматически).
# Локально (npm run dev): если не задано — используется http://127.0.0.1:3000/api
# Продакшен: укажите ваш деплой, например:
# VITE_API_URL=https://lfk-b-svetlanagolovchanskaya.amvera.io/api

# Единственный e-mail для кнопки «Специалист» при регистрации (как ALLOWED_SPECIALIST_EMAIL в backend/.env)
# VITE_ALLOWED_SPECIALIST_EMAIL=Sharunkina2014@yandex.ru

# Clerk: Publishable Key из Dashboard (https://dashboard.clerk.com)
# Используется для входа/регистрации и восстановления пароля
VITE_CLERK_PUBLISHABLE_KEY=

# Sentry DSN для отслеживания ошибок фронтенда (https://sentry.io → Project Settings → DSN)
VITE_SENTRY_DSN=

# Яндекс Метрика — идентификатор счётчика (https://metrika.yandex.ru)
VITE_YANDEX_METRIKA_ID=
