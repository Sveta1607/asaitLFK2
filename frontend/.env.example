# Этот блок создаётся, чтобы фронтенд обращался к продакшен-бэкенду на Amvera.
VITE_API_URL=https://lfk-b-svetlanagolovchanskaya.amvera.io/api

# Clerk: Publishable Key из Dashboard (https://dashboard.clerk.com)
