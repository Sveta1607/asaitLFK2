# URL бэкенда API.
# Используем 127.0.0.1, чтобы явно обращаться по IPv4 и избежать возможных
# проблем с тем, как разные браузеры резолвят localhost (IPv4/IPv6).
VITE_API_URL=http://127.0.0.1:3000/api

# Ключ Clerk для входа/регистрации (из Dashboard → API Keys → Publishable key)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_ZXhwZXJ0LWZvd2wtOTAuY2xlcmsuYWNjb3VudHMuZGV2JA
VITE_API_URL=http://localhost:3000/api
VITE_CLERK_PUBLISHABLE_KEY=pk_test_aHVtb3JvdXMtbW9sbHktNTUuY2xlcmsuYWNjb3VudHMuZGV2JA