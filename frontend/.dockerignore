# Контекст сборки — папка frontend (Amvera: корень репозитория проекта = frontend).
# Цель: не отправлять в демон Docker лишние сотни МБ (node_modules, dist) и секреты из .env.

# Зависимости и результат сборки — в образе ставятся через npm ci и создаётся заново при RUN npm run build.
node_modules/
dist/

# Локальные секреты и оверрайды; публичные ключи для сборки задаются через ARG в Amvera, не через копирование .env.
.env
.env.*
!.env.example

# Git и служебные каталоги IDE — не нужны для npm run build.
.git/
.gitignore
.cursor/
.vscode/
.idea/

# Логи и кэши пакетных менеджеров / линтеров.
*.log
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
*.tsbuildinfo

# Тесты и отчёты (если появятся) — в production-образ фронта не входят.
coverage/
cypress/
playwright-report/
test-results/
__tests__/

# Системные и временные файлы.
.DS_Store
Thumbs.db
*.swp
*~
