# Этот блок создаётся, чтобы не копировать директории зависимостей и сборки.
node_modules/
dist/

# Этот блок создаётся, чтобы не копировать локальные env-файлы в образ.
.env
.env.*

# Этот блок создаётся, чтобы не включать git/cursor служебные файлы.
.git/
.gitignore
.cursor/

# Этот блок создаётся, чтобы исключить временные и лог-файлы.
*.log
npm-debug.log*
yarn-error.log*
