# .env - переменные окружения для backend

# Порт сервера
PORT=3000

# Хост (0.0.0.0 — слушать все интерфейсы)
HOST=0.0.0.0

# Строка подключения к PostgreSQL (замени user/password/host/db на свои)
# Пример для локальной разработки:
DATABASE_URL=postgresql+psycopg2://postgres:Svsv12345@localhost:5432/lfk_app

# Дополнительные CORS origins через запятую (опционально)
# CORS_ORIGINS=http://localhost:8080,https://myapp.example.com

# Clerk: настройки домена и JWKS для проверки JWT
CLERK_JWKS_URL=https://humorous-molly-55.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://humorous-molly-55.clerk.accounts.dev

# Sentry DSN для отслеживания ошибок бэкенда (https://sentry.io → Project Settings → DSN)
SENTRY_DSN=https://7e2c6888ff014f1290df1e0719b3820a@app.glitchtip.com/21396
