# Этот блок создаётся, чтобы не копировать кэш Python в образ.
__pycache__/
*.pyc
*.pyo
*.pyd

# Этот блок создаётся, чтобы не включать локальные окружения и служебные файлы.
.venv/
venv/
.env
.env.*

# Этот блок создаётся, чтобы не копировать данные git/cursor в образ.
.git/
.gitignore
.cursor/

# Этот блок создаётся, чтобы исключить артефакты локальной БД и логов.
*.db
*.sqlite
*.log
