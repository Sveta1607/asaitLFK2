# .env.example — пример переменных окружения
# Скопируйте в .env и при необходимости измените

# Этот блок создаётся, чтобы API слушал стандартный порт сервиса в Docker.
PORT=3000
HOST=0.0.0.0

# База данных: раскомментируйте и подставьте свой пароль для PostgreSQL.
# ВАЖНО для облака (Amvera): не используйте localhost, указывайте внешний хост БД.
# DATABASE_URL=postgresql+psycopg2://postgres:ВАШ_ПАРОЛЬ@localhost:5432/lfk_app
#
# Если DATABASE_URL не задан — используется SQLite:
# — в Docker/Amvera (каталог /data существует): sqlite:////data/lfk_app.db  (persistent volume)
# — локально: sqlite:///./lfk_app.db

# Дополнительные CORS origins (через запятую)
# CORS_ORIGINS=http://localhost:8080

# Clerk: для проверки JWT токенов (https://dashboard.clerk.com)
# CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
# CLERK_ISSUER=https://<your-clerk-domain>

# Sentry DSN для отслеживания ошибок бэкенда (https://sentry.io → Project Settings → DSN)
# SENTRY_DSN=https://xxxxx@sentry.io/yyyyy

# Секрет для Telegram-бота (тот же в telegram-bot/.env → TELEGRAM_BOT_API_SECRET)
# TELEGRAM_BOT_API_SECRET=сгенерируйте_длинную_случайную_строку

# Единственный e-mail, которому разрешена регистрация как специалист (совпадает с VITE_ALLOWED_SPECIALIST_EMAIL на фронте)
# ALLOWED_SPECIALIST_EMAIL=Sharunkina2014@yandex.ru
TELEGRAM_BOT_API_SECRET=Svsv9518653906!Svsv12345