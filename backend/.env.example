# .env.example — пример переменных окружения
# Скопируйте в .env и при необходимости измените

PORT=3000
HOST=0.0.0.0

# База данных: раскомментируйте и подставьте свой пароль для PostgreSQL
# DATABASE_URL=postgresql+psycopg2://postgres:ВАШ_ПАРОЛЬ@localhost:5432/lfk_app
# Если не задано — используется SQLite: sqlite:///./lfk_app.db

# Дополнительные CORS origins (через запятую)
# CORS_ORIGINS=http://localhost:8080
