# Этот этап создаётся, чтобы использовать минимальный официальный Python-образ
# и запускать бэкенд отдельно от фронтенда.
FROM python:3.12-slim

# Этот блок создаётся, чтобы задать рабочую директорию только для backend-кода.
WORKDIR /app

# Этот блок создаётся, чтобы Amvera могла собрать образ при контексте = корень репо.
# Контекст сборки на Amvera — корень репозитория, поэтому пути относительно него.
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Этот блок создаётся, чтобы прервать сборку сразу, если критичные модули не установились.
RUN python -c "import jwt, requests, jwcrypto; print('deps ok')"

# Этот блок создаётся, чтобы скопировать только файлы бэкенда из корня репо.
COPY backend/ .

# Этот блок создаётся, чтобы создать каталог для persistent volume Amvera.
# SQLite-файл хранится в /data и сохраняется между пересборками контейнера.
RUN mkdir -p /data

# Этот блок создаётся, чтобы документировать стандартный порт API-сервиса.
EXPOSE 3000

# Этот блок создаётся, чтобы запустить FastAPI как отдельный автономный процесс.
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "3000"]
