# .dockerignore в корне — используется при сборке backend на Amvera.
# Контекст сборки = корень репо, этот файл исключает лишнее и ускоряет сборку.

# Фронтенд — для backend не нужен, экономит ~400+ MB контекста.
frontend/

# Git и служебные папки.
.git/
.gitignore
.cursor/

# Документация и конфиги, не нужные в образе.
*.md
docker-compose.yml

# Конфиг Amvera для фронта (у backend свой amvera.yaml в корне).
frontend/amvera.yaml
