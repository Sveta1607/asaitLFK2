# .dockerignore в корне — используется при сборке backend И frontend на Amvera.
# ВАЖНО: frontend/ НЕ исключаем — проект front использует Dockerfile.frontend с COPY frontend/.
# Исключение frontend/ приводило к тому, что на Amvera собирался старый/пустой дизайн.

# Git и служебные папки.
.git/
.gitignore
.cursor/

# Python-кэш — не должен попадать в образ (собирается под другую версию Python).
**/__pycache__/
**/*.pyc
**/*.pyo

# Документация и конфиги, не нужные в образе.
*.md
docker-compose.yml

# Конфиг Amvera для фронта (у backend свой amvera.yaml в корне).
frontend/amvera.yaml
